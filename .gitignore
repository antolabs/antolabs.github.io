# Compiled CSS is generated from assets/css/main.scss — do not commit it.
# A committed copy here shadows the SCSS pipeline (Jekyll destination conflict),
# which silently serves stale CSS and breaks _sass/ edits locally.
assets/css/main.css
assets/css/main.css.map

# Generated by jekyll-sitemap / jekyll-feed at build time. A committed copy
# shadows the plugin and serves a stale sitemap/feed (dead URLs, missing pages).
sitemap.xml
feed.xml

# Never commit PowerPoint decks to this public repo (internal/working material).
*.pptx

# Local agent/IDE working files (audit artifacts contain the operator's IP/UA).
.agent/
